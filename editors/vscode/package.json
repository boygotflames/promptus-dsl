{
  "name": "llm-vscode",
  "displayName": ".llm Syntax Support",
  "description": "Minimal VS Code support for .llm surface files",
  "version": "0.1.0",
  "publisher": "llm-format",
  "license": "MIT",
  "icon": "images/Promptus 128x128.png",
  "main": "./extension.js",
  "activationEvents": ["onLanguage:llm"],
  "scripts": {
    "package": "vsce package",
    "build": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "llm",
        "aliases": [
          "llm",
          ".llm"
        ],
        "extensions": [
          ".llm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "llm",
        "scopeName": "source.llm",
        "path": "./syntaxes/llm.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": ".llm",
      "properties": {
        "llm.formatterPath": {
          "type": "string",
          "default": "",
          "description": "Path to the llm_format binary. Leave empty to use PATH."
        }
      }
    }
  }
}
